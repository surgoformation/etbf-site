    <div class="chips-wrap">
      <div class="chip-opt"><input type="radio" name="contact_pref" id="cp1" value="appel_video"><label class="chip-label" for="cp1">📹 Appel vidéo (Google Meet, Zoom)</label></div>
      <div class="chip-opt"><input type="radio" name="contact_pref" id="cp2" value="appel_tel"><label class="chip-label" for="cp2">📞 Appel téléphonique</label></div>
      <div class="chip-opt"><input type="radio" name="contact_pref" id="cp3" value="email_retour"><label class="chip-label" for="cp3">📧 Retour par email d'abord</label></div>
      <div class="chip-opt"><input type="radio" name="contact_pref" id="cp4" value="whatsapp"><label class="chip-label" for="cp4">💬 WhatsApp</label></div>
    </div>
  </div>

  <div class="field-group">
    <label class="field-label">Disponibilités préférées pour un premier échange</label>
    <input type="text" class="field-control" id="disponibilites" placeholder="Ex : Mardi et jeudi matin, à partir de 9h — ou : Vendredi toute la journée">
  </div>

  <!-- RECAP BOX -->
  <div style="background:var(--orange-bg);border:1px solid rgba(245,158,11,.25);border-radius:var(--radius);padding:20px 22px;margin-top:28px;">
    <div style="font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--orange-dark);margin-bottom:6px;">Votre diagnostic sera envoyé à</div>
    <div style="font-weight:700;font-size:18px;">etbf.ai@gmail.com</div>
    <div style="font-size:13px;color:var(--muted);margin-top:4px;">Notre équipe vous répond sous 24h avec une analyse personnalisée et un plan d'action concret.</div>
  </div>

  <div class="q-nav">
    <button class="btn-prev" onclick="prevStep()">← Retour</button>
    <div style="display:flex;align-items:center;gap:16px;">
      <div class="progress-dots" id="dots7"></div>
      <button class="btn-next btn-submit-final" onclick="submitForm()">Envoyer mon diagnostic 🚀</button>
    </div>
  </div>
</div>

<!-- SUCCESS SCREEN -->
<div class="success-screen" id="successScreen">
  <div class="success-icon-wrap">✓</div>
  <h2 class="success-title">Diagnostic envoyé !</h2>
  <p class="success-sub">Merci. Notre équipe analyse votre questionnaire et vous contacte sous 24h avec un plan d'action personnalisé et une estimation de ROI.</p>
  <button class="btn-print" onclick="window.print()">🖨️ Imprimer / Sauvegarder PDF</button>
</div>

</main>

<script>
// CURSOR
const cur=document.getElementById('cur'),ring=document.getElementById('ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function ar(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(ar);})();
document.querySelectorAll('a,button,input,select,textarea,label').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.style.width='5px';cur.style.height='5px';ring.style.width='52px';ring.style.height='52px';});
  el.addEventListener('mouseleave',()=>{cur.style.width='10px';cur.style.height='10px';ring.style.width='36px';ring.style.height='36px';});
});

// STEPS
const TOTAL=7;
let current=1;
function updateUI(){
  document.querySelectorAll('.step').forEach((s,i)=>{s.classList.toggle('active',i+1===current);});
  document.getElementById('stepNum').textContent=current;
  document.getElementById('progress-top').style.width=((current-1)/(TOTAL-1)*100)+'%';
  for(let i=1;i<=TOTAL;i++){
    const dots=document.getElementById('dots'+i);
    if(dots){
      dots.innerHTML='';
      for(let d=1;d<=TOTAL;d++){
        const div=document.createElement('div');
        div.className='prog-dot';
        if(d<current)div.classList.add('done');
        if(d===current)div.classList.add('active');
        dots.appendChild(div);
      }
    }
  }
  window.scrollTo({top:0,behavior:'smooth'});
}
function nextStep(){if(current<TOTAL){current++;updateUI();}}
function prevStep(){if(current>1){current--;updateUI();}}
updateUI();

// CHAR COUNT
function cc(el,id){document.getElementById(id).textContent=el.value.length;}

// HELPERS
function v(id){const el=document.getElementById(id);return el?el.value.trim():'';}
function getCheckedBoxes(ids){return ids.map(id=>document.getElementById(id)).filter(e=>e&&e.checked).map(e=>e.value).join(', ');}
function getRadioVal(name){const el=document.querySelector(`input[name="${name}"]:checked`);return el?el.value:'—';}

// SUBMIT — Web3Forms
async function submitForm(){
  if(!v('prenom')||!v('email')||!v('societe')){
    alert('Merci de remplir les champs obligatoires (prénom, email, société).');
    return;
  }

  const data={
    prenom:v('prenom'),nom:v('nom'),email:v('email'),tel:v('tel'),
    societe:v('societe'),secteur:v('secteur'),poste:v('poste'),taille:v('taille'),ca:v('ca'),
    besoin_type:getRadioVal('besoin_type'),probleme:v('probleme'),
    temps_perdu:v('temps_perdu'),nb_personnes:v('nb_personnes_impactees'),anciennete:getRadioVal('anciennete'),
    entrees:getCheckedBoxes(['e_email','e_form','e_crm','e_cmd','e_doc','e_api','e_manuel','e_heure','e_autre']),
    entree_detail:v('entree_detail'),
    traitement:getCheckedBoxes(['t_humain','t_excel','t_logiciel','t_email_manu','t_copier','t_partiel']),
    traitement_detail:v('traitement_detail'),decisions:getRadioVal('decision'),regles:v('regles_decision'),
    sorties:getCheckedBoxes(['s_email','s_notif','s_crm','s_doc_gen','s_rapport','s_task','s_bdd','s_autre']),
    sortie_detail:v('sortie_detail'),exceptions:v('exceptions'),
    frequence:getRadioVal('frequence'),volume:v('volume'),
    outils_crm:getCheckedBoxes(['crm_hubspot','crm_salesforce','crm_pipe','crm_zoho','crm_notion','crm_airtable','crm_excel','crm_autre']),
    outils_com:getCheckedBoxes(['com_gmail','com_outlook','com_slack','com_teams','com_notion','com_whatsapp','com_wp']),
    outils_pm:getCheckedBoxes(['pm_notion','pm_asana','pm_monday','pm_trello','pm_jira','pm_clickup','pm_linear']),
    outils_ec:getCheckedBoxes(['ec_shopify','ec_woo','ec_stripe','ec_pennylane','ec_quickbooks','ec_sage','ec_sellsy']),
    outils_auto:getCheckedBoxes(['auto_make','auto_zapier','auto_n8n','auto_power','auto_aucun']),
    outils_autres:v('outils_autres'),api_dispo:getRadioVal('api_dispo'),
    objectifs:getCheckedBoxes(['obj1','obj2','obj3','obj4','obj5','obj6']),
    roi_target:getRadioVal('roi_target'),kpi_principal:v('kpi_principal'),
    urgence:getRadioVal('urgence'),implication:getRadioVal('implication'),
    budget:getRadioVal('budget'),decideur:getRadioVal('decideur'),
    experience_presta:getRadioVal('experience_presta'),
    contraintes:getCheckedBoxes(['c_rgpd','c_hebergement','c_si','c_secteur','c_forma','c_aucune']),
    source:v('source'),complement:v('complement'),
    douleur:getRadioVal('douleur'),contact_pref:getRadioVal('contact_pref'),disponibilites:v('disponibilites'),
  };

  const btn=document.querySelector('.btn-submit-final');
  btn.textContent='Envoi en cours…';btn.disabled=true;

  const msg=`=== DIAGNOSTIC ETBF ===
Date : ${new Date().toLocaleString('fr-FR')}

── CONTACT ──
Nom : ${data.prenom} ${data.nom}
Email : ${data.email}
Téléphone : ${data.tel||'—'}
Société : ${data.societe}
Secteur : ${data.secteur}
Poste : ${data.poste}
Taille équipe : ${data.taille||'—'}
CA annuel : ${data.ca||'—'}

── LE PROBLÈME ──
Type de besoin : ${data.besoin_type}
Problème vécu : ${data.probleme}
Temps perdu : ${data.temps_perdu||'—'}
Personnes impactées : ${data.nb_personnes||'—'}
Ancienneté : ${data.anciennete}

── PROCESSUS ──
Entrées : ${data.entrees||'—'}
Détail entrée : ${data.entree_detail||'—'}
Traitement : ${data.traitement||'—'}
Étapes : ${data.traitement_detail||'—'}
Décisions : ${data.decisions} — ${data.regles||'—'}
Sorties : ${data.sorties||'—'}
Sortie idéale : ${data.sortie_detail||'—'}
Exceptions : ${data.exceptions||'—'}
Fréquence : ${data.frequence||'—'} / Volume : ${data.volume||'—'}

── OUTILS ──
CRM : ${data.outils_crm||'—'}
Communication : ${data.outils_com||'—'}
Projets : ${data.outils_pm||'—'}
E-commerce : ${data.outils_ec||'—'}
Automatisation : ${data.outils_auto||'—'}
Autres : ${data.outils_autres||'—'}
APIs : ${data.api_dispo}

── OBJECTIFS ──
Objectifs : ${data.objectifs||'—'}
ROI cible : ${data.roi_target||'—'}
KPI : ${data.kpi_principal||'—'}
Urgence : ${data.urgence||'—'}
Implication : ${data.implication||'—'}

── BUDGET & DÉCISION ──
Budget : ${data.budget||'—'}
Décideur : ${data.decideur||'—'}
Expérience : ${data.experience_presta||'—'}
Contraintes : ${data.contraintes||'—'}
Source : ${data.source||'—'}

── DIVERS ──
Niveau de douleur : ${data.douleur}/10
Complément : ${data.complement||'—'}
Contact préféré : ${data.contact_pref||'—'}
Disponibilités : ${data.disponibilites||'—'}`;

  try{
    const res=await fetch('https://api.web3forms.com/submit',{
      method:'POST',
      headers:{'Content-Type':'application/json','Accept':'application/json'},
      body:JSON.stringify({
        access_key:'27b1f3d2-a5e3-49d8-ba8b-6c97441b5572',
        subject:`[ETBF Diagnostic] ${data.prenom} ${data.nom} — ${data.societe}`,
        from_name:'ETBF Questionnaire',
        message:msg,
        email:data.email,
      })
    });
    const r=await res.json();
    if(r.success){showSuccess();}
    else{btn.textContent='Envoyer mon diagnostic 🚀';btn.disabled=false;alert('Erreur lors de l\'envoi. Veuillez réessayer.');}
  }catch(e){
    btn.textContent='Envoyer mon diagnostic 🚀';btn.disabled=false;
    alert('Erreur réseau. Veuillez réessayer.');
  }
}

function showSuccess(){
  document.querySelector('.q-wrap').style.display='none';
  document.querySelector('.q-header').style.display='none';
  document.getElementById('progress-top').style.width='100%';
  document.getElementById('successScreen').style.display='block';
}
</script>

</body>
</html>
