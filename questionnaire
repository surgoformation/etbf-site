      <div class="scale-opt"><input type="radio" name="douleur" id="dl4" value="4"><label class="scale-label" for="dl4">4</label></div>
      <div class="scale-opt"><input type="radio" name="douleur" id="dl5" value="5"><label class="scale-label" for="dl5">5</label></div>
      <div class="scale-opt"><input type="radio" name="douleur" id="dl6" value="6"><label class="scale-label" for="dl6">6</label></div>
      <div class="scale-opt"><input type="radio" name="douleur" id="dl7" value="7"><label class="scale-label" for="dl7">7</label></div>
      <div class="scale-opt"><input type="radio" name="douleur" id="dl8" value="8"><label class="scale-label" for="dl8">8</label></div>
