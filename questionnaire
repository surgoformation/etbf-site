      <div class="chip-opt"><input type="checkbox" id="c_secteur" value="reglementation_sectorielle"><label class="chip-label" for="c_secteur">Réglementation sectorielle</label></div>
      <div class="chip-opt"><input type="checkbox" id="c_forma" value="formation_requise"><label class="chip-label" for="c_forma">Formation de l'équipe requise</label></div>
      <div class="chip-opt"><input type="checkbox" id="c_aucune" value="aucune"><label class="chip-label" for="c_aucune">Aucune contrainte</label></div>
    </div>
  </div>

  <div class="field-group">
    <label class="field-label">Comment nous avez-vous trouvé ?</label>
    <select class="field-control" id="source" style="max-width:360px;">
      <option value="">Sélectionnez</option>
      <option>Bouche à oreille / recommandation</option>
      <option>Recherche Google</option>
      <option>LinkedIn</option>
      <option>Réseaux sociaux</option>
      <option>Podcast ou YouTube</option>
