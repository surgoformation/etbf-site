  <div class="q-nav">
    <button class="btn-prev" onclick="prevStep()">← Retour</button>
    <div style="display:flex;align-items:center;gap:16px;">
      <div class="progress-dots" id="dots6"></div>
      <button class="btn-next" onclick="nextStep()">Suivant →</button>
    </div>
  </div>
</div>

<!-- STEP 7 — TRANSITION VERS GOOGLE FORM -->
<div class="step" id="step-7">
  <div class="step-label"><span class="step-dot"></span> Étape 7 — Dernière ligne droite</div>
  <h1 class="step-title">Y a-t-il autre chose<br><span style="color:var(--orange)">à nous dire ?</span></h1>
  <p class="step-sub">Un espace libre pour tout ce qui n'entre pas dans les cases précédentes. Les détails font souvent toute la différence.</p>

  <div class="field-group">
    <label class="field-label">Informations complémentaires, contexte, ou exemple de cas concret</label>
    <textarea class="field-control" id="complement" placeholder="Tout ce qui vous semble utile : contexte projet, tentatives précédentes, workflows connexes, contraintes cachées, exemples de documents traités, liens vers des outils…" style="min-height:160px;" oninput="cc(this,'cc_comp')" maxlength="1000"></textarea>
    <div class="char-count"><span id="cc_comp">0</span>/1000</div>
  </div>

  <div class="field-group">
    <label class="field-label">Sur une échelle de 1 à 10, à quel point ce problème est-il douloureux pour vous au quotidien ?</label>
