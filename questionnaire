<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ETBF — Questionnaire de diagnostic</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f7f6f1;
  --white: #ffffff;
  --black: #0d0d0d;
  --orange: #f59e0b;
  --orange-dark: #d97706;
  --orange-bg: #fffbeb;
  --muted: #6b7280;
  --light: #9ca3af;
  --border: #e5e7eb;
  --font: 'Plus Jakarta Sans', sans-serif;
  --mono: 'Space Mono', monospace;
  --radius: 14px;
  --radius-sm: 8px;
  --tr: 0.3s cubic-bezier(0.16,1,0.3,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;overflow-x:hidden;}
body{background:var(--bg);color:var(--black);font-family:var(--font);min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:0;cursor:none;}

/* CURSOR */
#cur{position:fixed;width:10px;height:10px;background:var(--orange);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .25s,height .25s;}
#ring{position:fixed;width:36px;height:36px;border:1.5px solid rgba(245,158,11,.35);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .3s,height .3s;}
a,button,input,select,textarea,label{cursor:none;}

/* PROGRESS BAR TOP */
#progress-top{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--orange),var(--orange-dark));z-index:9000;transition:width .5s var(--tr);}

/* HEADER */
.q-header{width:100%;max-width:760px;padding:44px 24px 0;display:flex;align-items:center;justify-content:space-between;}
.logo{font-weight:800;font-size:22px;letter-spacing:-.5px;color:var(--black);text-decoration:none;}
.logo span{color:var(--orange);}
.step-indicator{font-family:var(--mono);font-size:12px;color:var(--muted);}
.step-indicator strong{color:var(--black);}

/* MAIN */
.q-wrap{width:100%;max-width:760px;padding:32px 24px 80px;}

/* STEP */
.step{display:none;animation:fadeUp .45s var(--tr) both;}
.step.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}

/* STEP LABEL */
.step-label{display:inline-flex;align-items:center;gap:8px;background:var(--orange-bg);border:1px solid rgba(245,158,11,.25);padding:5px 13px;border-radius:100px;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--orange-dark);margin-bottom:18px;}
.step-dot{width:6px;height:6px;border-radius:50%;background:var(--orange);}

/* STEP TITLE */
.step-title{font-weight:800;font-size:clamp(26px,4vw,42px);letter-spacing:-1.5px;line-height:1.08;margin-bottom:10px;}
.step-sub{font-size:15px;color:var(--muted);line-height:1.7;margin-bottom:36px;max-width:580px;}

/* FORM ELEMENTS */
.field-group{margin-bottom:20px;}
.field-label{font-size:13px;font-weight:600;color:var(--black);margin-bottom:8px;display:block;}
.field-label .req{color:var(--orange);}
.field-hint{font-size:12px;color:var(--light);margin-top:5px;line-height:1.5;}
.field-control{width:100%;background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:12px 14px;font-family:var(--font);font-size:14px;color:var(--black);outline:none;transition:border-color .2s,box-shadow .2s;}
.field-control:focus{border-color:var(--orange);box-shadow:0 0 0 3px rgba(245,158,11,.12);}
.field-control::placeholder{color:var(--light);}
textarea.field-control{resize:vertical;min-height:110px;}
select.field-control option{background:#fff;}

/* GRID */
.form-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
@media(max-width:600px){.form-grid-2{grid-template-columns:1fr;}}

/* CHOICE CARDS */
.choice-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-top:4px;}
.choice-card{position:relative;}
.choice-card input{position:absolute;opacity:0;width:0;height:0;}
.choice-label{display:flex;flex-direction:column;gap:5px;padding:14px 16px;background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius-sm);cursor:none;transition:all .2s;user-select:none;}
.choice-label:hover{border-color:rgba(245,158,11,.4);}
.choice-card input:checked + .choice-label{border-color:var(--orange);background:var(--orange-bg);}
.choice-icon{font-size:20px;margin-bottom:2px;}
.choice-title{font-weight:700;font-size:14px;}
.choice-desc{font-size:12px;color:var(--muted);line-height:1.4;}

/* INLINE CHIPS */
.chips-wrap{display:flex;flex-wrap:wrap;gap:8px;margin-top:6px;}
.chip-opt{position:relative;}
.chip-opt input{position:absolute;opacity:0;width:0;height:0;}
.chip-label{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;background:var(--white);border:1.5px solid var(--border);border-radius:100px;font-size:13px;font-weight:500;color:var(--muted);cursor:none;transition:all .2s;user-select:none;}
.chip-label:hover{border-color:rgba(245,158,11,.4);color:var(--black);}
.chip-opt input:checked + .chip-label{border-color:var(--orange);background:var(--orange-bg);color:var(--black);}

/* PROCESS FLOW */
.flow-wrap{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);padding:24px;margin-bottom:20px;}
.flow-step{display:flex;gap:14px;margin-bottom:20px;}
.flow-step:last-child{margin-bottom:0;}
.flow-badge{width:32px;height:32px;min-width:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:#fff;flex-shrink:0;margin-top:2px;}
.flow-in{background:#3b82f6;}
.flow-proc{background:var(--orange);}
.flow-out{background:#22c55e;}
.flow-step-content{flex:1;}
.flow-step-label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px;}
.flow-in-color{color:#3b82f6;}
.flow-proc-color{color:var(--orange-dark);}
.flow-out-color{color:#16a34a;}
.flow-line{width:2px;height:20px;background:var(--border);margin-left:15px;margin-bottom:16px;}

/* SCALE */
.scale-wrap{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px;}
.scale-opt{position:relative;}
.scale-opt input{position:absolute;opacity:0;width:0;height:0;}
.scale-label{width:44px;height:44px;display:flex;align-items:center;justify-content:center;background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius-sm);font-weight:700;font-size:15px;cursor:none;transition:all .2s;user-select:none;}
.scale-label:hover{border-color:rgba(245,158,11,.4);}
.scale-opt input:checked + .scale-label{background:var(--orange);border-color:var(--orange);color:#fff;}
.scale-ends{display:flex;justify-content:space-between;margin-top:6px;font-size:12px;color:var(--light);}

/* NAV BUTTONS */
.q-nav{display:flex;justify-content:space-between;align-items:center;margin-top:40px;padding-top:32px;border-top:1px solid var(--border);}
.btn-prev{display:inline-flex;align-items:center;gap:8px;background:var(--white);color:var(--muted);font-family:var(--font);font-weight:600;font-size:14px;padding:12px 20px;border:1.5px solid var(--border);border-radius:var(--radius-sm);cursor:none;transition:all .2s;}
.btn-prev:hover{color:var(--black);border-color:#999;}
.btn-next{display:inline-flex;align-items:center;gap:8px;background:var(--black);color:#fff;font-family:var(--font);font-weight:700;font-size:14px;padding:13px 28px;border:none;border-radius:var(--radius-sm);cursor:none;transition:all var(--tr);}
.btn-next:hover{background:#1a1a1a;transform:translateY(-2px);box-shadow:0 8px 20px rgba(0,0,0,.2);}
.btn-submit-final{background:var(--orange);}
.btn-submit-final:hover{background:var(--orange-dark);box-shadow:0 8px 20px rgba(245,158,11,.35);}

/* PROGRESS DOTS */
.progress-dots{display:flex;gap:6px;}
.prog-dot{width:8px;height:8px;border-radius:50%;background:var(--border);transition:all .4s;}
.prog-dot.done{background:var(--orange-dark);}
.prog-dot.active{background:var(--orange);width:22px;border-radius:100px;}

/* SECTION DIVIDER */
.divider{border:none;border-top:1px solid var(--border);margin:24px 0;}
.section-mini-title{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--orange);margin-bottom:14px;display:block;}

/* SUCCESS */
.success-screen{display:none;text-align:center;padding:80px 20px;}
.success-icon-wrap{width:80px;height:80px;background:var(--orange-bg);border:2px solid var(--orange);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;font-size:36px;}
.success-title{font-weight:800;font-size:36px;letter-spacing:-1.5px;margin-bottom:12px;}
.success-sub{font-size:16px;color:var(--muted);line-height:1.7;max-width:480px;margin:0 auto 32px;}
.btn-print{display:inline-flex;align-items:center;gap:8px;background:var(--black);color:#fff;font-family:var(--font);font-weight:600;font-size:14px;padding:13px 24px;border:none;border-radius:var(--radius-sm);cursor:none;transition:all var(--tr);}
.btn-print:hover{background:#222;transform:translateY(-2px);}

/* TOOLTIP */
.tooltip-wrap{position:relative;display:inline-block;margin-left:6px;}
.tooltip-icon{width:16px;height:16px;border-radius:50%;background:var(--border);color:var(--muted);font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;vertical-align:middle;}
.tooltip-text{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);background:var(--black);color:#fff;font-size:12px;padding:8px 12px;border-radius:6px;opacity:0;pointer-events:none;transition:opacity .2s;z-index:10;line-height:1.5;max-width:220px;white-space:normal;text-align:center;}
.tooltip-wrap:hover .tooltip-text{opacity:1;}

/* CHAR COUNT */
.char-count{font-size:11px;color:var(--light);text-align:right;margin-top:4px;}
.req-note{font-size:12px;color:var(--light);margin-bottom:28px;}

/* TRANSITION BOX */
.transition-box{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);padding:28px 30px;margin-bottom:28px;display:flex;align-items:flex-start;gap:18px;}
.transition-icon{font-size:32px;flex-shrink:0;}
.transition-title{font-weight:700;font-size:17px;margin-bottom:6px;}
.transition-text{font-size:14px;color:var(--muted);line-height:1.7;}
.transition-steps{display:flex;flex-direction:column;gap:10px;margin-top:14px;}
.t-step{display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;}
.t-step-badge{width:24px;height:24px;min-width:24px;background:var(--orange-bg);border:1px solid rgba(245,158,11,.3);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:var(--orange-dark);}
</style>
</head>
<body>

<div id="cur"></div>
<div id="ring"></div>
<div id="progress-top" style="width:0%"></div>

<header class="q-header">
  <a href="/" class="logo">ET<span>BF</span></a>
  <div class="step-indicator">Étape <strong id="stepNum">1</strong> / <strong>7</strong></div>
</header>

<main class="q-wrap">

<!-- STEP 1 -->
<div class="step active" id="step-1">
  <div class="step-label"><span class="step-dot"></span> Étape 1 — Contexte</div>
  <h1 class="step-title">Votre entreprise<br>en quelques mots.</h1>
  <p class="step-sub">Ces informations nous permettent de comprendre votre contexte avant d'analyser vos besoins d'automatisation.</p>
  <p class="req-note">Les champs marqués <span style="color:var(--orange)">*</span> sont obligatoires.</p>

  <div class="form-grid-2">
    <div class="field-group">
      <label class="field-label">Prénom <span class="req">*</span></label>
      <input type="text" class="field-control" id="prenom" placeholder="Jean" required>
    </div>
    <div class="field-group">
      <label class="field-label">Nom <span class="req">*</span></label>
      <input type="text" class="field-control" id="nom" placeholder="Dupont" required>
    </div>
    <div class="field-group">
      <label class="field-label">Email professionnel <span class="req">*</span></label>
      <input type="email" class="field-control" id="email" placeholder="jean@societe.fr" required>
    </div>
    <div class="field-group">
      <label class="field-label">Téléphone</label>
      <input type="tel" class="field-control" id="tel" placeholder="+33 6 00 00 00 00">
    </div>
  </div>

  <div class="field-group">
    <label class="field-label">Nom de l'entreprise <span class="req">*</span></label>
    <input type="text" class="field-control" id="societe" placeholder="Ma Société SAS" required>
  </div>

  <div class="form-grid-2">
    <div class="field-group">
      <label class="field-label">Secteur d'activité <span class="req">*</span></label>
      <select class="field-control" id="secteur" required>
        <option value="">Sélectionnez votre secteur</option>
        <option>E-commerce / Retail</option>
        <option>SaaS / Tech</option>
        <option>Services B2B</option>
        <option>Industrie / Manufacturing</option>
        <option>Immobilier</option>
        <option>Finance / Assurance</option>
        <option>Santé</option>
        <option>Formation / RH</option>
        <option>Marketing / Agence</option>
        <option>Juridique / Comptabilité</option>
        <option>Logistique</option>
        <option>Autre</option>
      </select>
    </div>
    <div class="field-group">
      <label class="field-label">Votre poste / fonction <span class="req">*</span></label>
      <input type="text" class="field-control" id="poste" placeholder="Directeur Général, Responsable Ops…" required>
    </div>
    <div class="field-group">
      <label class="field-label">Taille de l'équipe concernée</label>
      <select class="field-control" id="taille">
        <option value="">Nombre de personnes impactées</option>
        <option>1 personne (moi-même)</option>
        <option>2–5 personnes</option>
        <option>6–20 personnes</option>
        <option>21–50 personnes</option>
        <option>50+ personnes</option>
      </select>
    </div>
    <div class="field-group">
      <label class="field-label">Chiffre d'affaires annuel (approx.)</label>
      <select class="field-control" id="ca">
        <option value="">Sélectionnez une fourchette</option>
        <option>< 100 000 €</option>
        <option>100 000 – 500 000 €</option>
        <option>500 000 – 2 M€</option>
        <option>2 – 10 M€</option>
        <option>10 M€+</option>
      </select>
    </div>
  </div>

  <div class="q-nav">
    <div></div>
    <div style="display:flex;align-items:center;gap:16px;">
      <div class="progress-dots" id="dots1"></div>
      <button class="btn-next" onclick="nextStep()">Suivant →</button>
    </div>
  </div>
</div>

<!-- STEP 2 -->
<div class="step" id="step-2">
  <div class="step-label"><span class="step-dot"></span> Étape 2 — Le problème</div>
  <h1 class="step-title">Quel est votre<br><span style="color:var(--orange)">défi principal ?</span></h1>
  <p class="step-sub">Identifiez la douleur centrale que vous souhaitez résoudre avec l'automatisation ou l'IA.</p>

  <div class="field-group">
    <label class="field-label">Quel type de besoin vous amène ? <span class="req">*</span></label>
    <div class="choice-grid">
      <div class="choice-card"><input type="radio" name="besoin_type" id="bt1" value="automatisation_taches"><label class="choice-label" for="bt1"><span class="choice-icon">⚙️</span><span class="choice-title">Automatiser des tâches</span><span class="choice-desc">Répétitives, chronophages, manuelles</span></label></div>
      <div class="choice-card"><input type="radio" name="besoin_type" id="bt2" value="agent_ia"><label class="choice-label" for="bt2"><span class="choice-icon">🤖</span><span class="choice-title">Agent IA autonome</span><span class="choice-desc">Prendre des décisions, agir sans humain</span></label></div>
      <div class="choice-card"><input type="radio" name="besoin_type" id="bt3" value="integration_outils"><label class="choice-label" for="bt3"><span class="choice-icon">🔗</span><span class="choice-title">Connecter des outils</span><span class="choice-desc">CRM, ERP, apps métiers silotés</span></label></div>
      <div class="choice-card"><input type="radio" name="besoin_type" id="bt4" value="chatbot"><label class="choice-label" for="bt4"><span class="choice-icon">💬</span><span class="choice-title">Chatbot / Assistant IA</span><span class="choice-desc">SAV, qualification, support interne</span></label></div>
      <div class="choice-card"><input type="radio" name="besoin_type" id="bt5" value="reporting"><label class="choice-label" for="bt5"><span class="choice-icon">📊</span><span class="choice-title">Reporting automatique</span><span class="choice-desc">Tableaux de bord, KPIs, alertes</span></label></div>
      <div class="choice-card"><input type="radio" name="besoin_type" id="bt6" value="traitement_docs"><label class="choice-label" for="bt6"><span class="choice-icon">📄</span><span class="choice-title">Traitement de documents</span><span class="choice-desc">Factures, contrats, formulaires</span></label></div>
      <div class="choice-card"><input type="radio" name="besoin_type" id="bt7" value="autre"><label class="choice-label" for="bt7"><span class="choice-icon">💡</span><span class="choice-title">Autre / Je ne sais pas</span><span class="choice-desc">On vous guide dans l'identification</span></label></div>
    </div>
  </div>

  <div class="field-group">
    <label class="field-label">Décrivez le problème que vous vivez au quotidien <span class="req">*</span>
      <span class="tooltip-wrap"><span class="tooltip-icon">?</span><span class="tooltip-text">Soyez concret : "Je passe 3h par jour à recopier des emails dans le CRM" plutôt que "on manque d'efficacité"</span></span>
    </label>
    <textarea class="field-control" id="probleme" placeholder="Ex : Notre équipe commerciale passe 2h par jour à qualifier manuellement les leads entrants depuis notre formulaire web, les copier dans HubSpot, et envoyer un email de bienvenue personnalisé." oninput="cc(this,'cc_pb')" maxlength="800"></textarea>
    <div class="char-count"><span id="cc_pb">0</span>/800</div>
  </div>

  <div class="field-group">
    <label class="field-label">Combien de temps votre équipe perd-elle sur ce problème ?</label>
    <div class="form-grid-2">
      <select class="field-control" id="temps_perdu">
        <option value="">Fréquence</option>
        <option>Quelques minutes par jour</option>
        <option>30 min – 1h par jour</option>
        <option>1h – 3h par jour</option>
        <option>3h – 6h par jour</option>
        <option>Une journée entière par semaine</option>
        <option>Plusieurs jours par semaine</option>
      </select>
      <select class="field-control" id="nb_personnes_impactees">
        <option value="">Combien de personnes concernées</option>
        <option>Juste moi</option>
        <option>2 à 5 personnes</option>
        <option>6 à 20 personnes</option>
        <option>Toute l'entreprise</option>
      </select>
    </div>
  </div>

  <div class="field-group">
    <label class="field-label">Depuis combien de temps ce problème existe-t-il ?</label>
    <div class="chips-wrap">
      <div class="chip-opt"><input type="radio" name="anciennete" id="anc1" value="recent"><label class="chip-label" for="anc1">Récent (< 6 mois)</label></div>
      <div class="chip-opt"><input type="radio" name="anciennete" id="anc2" value="1an"><label class="chip-label" for="anc2">~ 1 an</label></div>
      <div class="chip-opt"><input type="radio" name="anciennete" id="anc3" value="2ans"><label class="chip-label" for="anc3">2 ans ou plus</label></div>
      <div class="chip-opt"><input type="radio" name="anciennete" id="anc4" value="toujours"><label class="chip-label" for="anc4">Depuis toujours</label></div>
    </div>
  </div>

  <div class="q-nav">
    <button class="btn-prev" onclick="prevStep()">← Retour</button>
    <div style="display:flex;align-items:center;gap:16px;">
      <div class="progress-dots" id="dots2"></div>
      <button class="btn-next" onclick="nextStep()">Suivant →</button>
    </div>
  </div>
</div>

<!-- STEP 3 -->
<div class="step" id="step-3">
  <div class="step-label"><span class="step-dot"></span> Étape 3 — Le processus actuel</div>
  <h1 class="step-title">Comment ça marche<br>aujourd'hui ?</h1>
  <p class="step-sub">C'est la section la plus importante. Plus vous êtes précis, mieux on peut automatiser. Décrivez le flux exact de votre processus.</p>

  <div class="flow-wrap">
    <div class="flow-step">
      <div class="flow-badge flow-in">↓</div>
      <div class="flow-step-content">
        <div class="flow-step-label flow-in-color">📥 Entrée — comment ça arrive</div>
        <div class="field-group" style="margin-bottom:12px;">
          <label class="field-label">Par où arrivent les données / déclencheurs ? <span class="req">*</span></label>
          <div class="chips-wrap">
            <div class="chip-opt"><input type="checkbox" id="e_email" value="email"><label class="chip-label" for="e_email">Email entrant</label></div>
            <div class="chip-opt"><input type="checkbox" id="e_form" value="formulaire"><label class="chip-label" for="e_form">Formulaire web</label></div>
            <div class="chip-opt"><input type="checkbox" id="e_crm" value="crm"><label class="chip-label" for="e_crm">CRM (nouveau lead)</label></div>
            <div class="chip-opt"><input type="checkbox" id="e_cmd" value="commande"><label class="chip-label" for="e_cmd">Commande / achat</label></div>
            <div class="chip-opt"><input type="checkbox" id="e_doc" value="document"><label class="chip-label" for="e_doc">Document / fichier</label></div>
            <div class="chip-opt"><input type="checkbox" id="e_api" value="api"><label class="chip-label" for="e_api">API / webhook</label></div>
            <div class="chip-opt"><input type="checkbox" id="e_manuel" value="manuel"><label class="chip-label" for="e_manuel">Action humaine manuelle</label></div>
            <div class="chip-opt"><input type="checkbox" id="e_heure" value="planifie"><label class="chip-label" for="e_heure">Planifié (heure/date)</label></div>
